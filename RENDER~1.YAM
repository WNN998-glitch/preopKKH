databases:
  - name: preop-checklist-db
    databaseName: preop_checklist
    user: preop_checklist
    plan: free

services:
  - type: web
    name: preop-checklist-app
    runtime: node
    buildCommand: npm install
    startCommand: npm start
    healthCheckPath: /healthz
    envVars:
      - key: DATABASE_URL
        fromDatabase:
          name: preop-checklist-db
          property: connectionString
